DNS_FILTER_DOH_UPSTREAM="https://cloudflare-dns.com/dns-query"
DNS_FILTER_DOH_BOOTSTRAP_IPS="1.1.1.1,1.0.0.1"
DNS_FILTER_DBPATH="./data/filter.sqlite"

DNS_FILTER_LOG_LEVEL=debug

DNS_FILTER_METRIC_ENABLE=true
DNS_FILTER_METRIC_PORT=2112

# Bootstrap admin: created on first run only. On subsequent restarts the value
# is ignored — change the password through the UI, then unset these vars.
DNS_FILTER_ADMIN_LOGIN=admin
DNS_FILTER_ADMIN_PASSWORD=changeme
# Cookie flags. For cross-origin dev set SAMESITE=None and SECURE=true behind https.
DNS_FILTER_COOKIE_SAMESITE=Lax
DNS_FILTER_COOKIE_SECURE=false

# Optional API keys for /api/domain/inspect external reputation checks.
# Leave empty to have the corresponding check return status=skipped.
DNS_FILTER_VT_KEY=
DNS_FILTER_URLSCAN_KEY=
DNS_FILTER_SAFE_BROWSING_KEY=

# Opt-in reputation enrichment of weak suggest candidates (score 10–29).
# OFF by default; needs a VT or Safe Browsing key to take effect. Durations use
# Go's time.ParseDuration ("168h", not "7d"). See README "Reputation enrichment".
DNS_FILTER_SUGGEST_INSPECT_ENABLED=false
DNS_FILTER_SUGGEST_INSPECT_BUDGET=5
DNS_FILTER_SUGGEST_INSPECT_INTERVAL=1h
DNS_FILTER_SUGGEST_INSPECT_CACHE_TTL=168h
DNS_FILTER_SUGGEST_INSPECT_PAUSE=20s
DNS_FILTER_SUGGEST_INSPECT_BACKOFF=30m
DNS_FILTER_SUGGEST_INSPECT_MAX_ERRORS=3
