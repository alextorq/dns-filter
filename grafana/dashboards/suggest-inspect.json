      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "targets": [
        { "expr": "sum(increase(suggest_inspect_decisions_total[24h]))", "legendFormat": "decisions", "refId": "A", "datasource": { "type": "prometheus" } }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" },
