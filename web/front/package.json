{
    "name": "nuxt-app",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "test": "vitest run",
        "test:watch": "vitest",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "generate:api": "swagger-typescript-api generate -p ../../docs/swagger.json -o app/api/generated -n Api.ts --axios --unwrap-response-data --modular --clean-output && perl -i -ne 'print unless m{^/\\* eslint-disable \\*/$}' app/api/generated/*.ts && eslint app/api/generated --fix"
    },
    "dependencies": {
        "@nuxt/ui": "^4.8.0",
        "autoprefixer": "^10.4.21",
        "axios": "^1.16.1",
        "chart.js": "^4.5.0",
        "nuxt": "^4.4.6",
        "postcss": "^8.5.15",
        "tailwindcss": "^4.1.13",
        "vue": "^3.5.21",
        "vue-router": "^4.5.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@nuxt/eslint": "^1.15.2",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "happy-dom": "^15.11.7",
        "prettier": "^3.8.3",
        "swagger-typescript-api": "^13.10.0",
        "vitest": "^4.1.7"
    }
}
